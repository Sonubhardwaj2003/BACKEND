<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="min-h-screen w-full bg-zinc-900 text-white p-10  outline-none">
        <h1 class="text-3xl font-bold mb-5">Create User</h1>
         <form action="/create" method="post" class="bg-zinc-800 p-5 w-full">
            <input class="px-3 py-2 rounded-lg border-2 border-zinc-700 bg-tansparent outline-none" type="text" placeholder="enter username" name="username">
            <input class="px-3 py-2 rounded-lg border-2 border-zinc-700 bg-tansparent outline-none ml-3" type="email" placeholder="enter email" name="email"> 
            <input class="px-3 py-2 rounded-lg border-2 border-zinc-700 bg-tansparent outline-none ml-3" type="password" placeholder="enter password" name="password">
            <input class="px-3 py-2 rounded-lg border-2 border-zinc-700 bg-tansparent outline-none ml-3" type="number" placeholder="enter age" name="age">

            <input class="px-3 py-2 rounded-lg border-2 border-zinc-700 bg-blue-600  ml-3" type="submit" value="Create User">
         </form>
    </div>
</body>
</html>