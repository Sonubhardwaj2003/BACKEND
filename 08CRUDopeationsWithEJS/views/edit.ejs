<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <div class="mb-10">
            <a class="text-blue-600 underline" href="/read">Update Users</a>
        </div>

        <h1 class="py-2 text-3xl mb-3">Create User</h1>

        <form action="/update/<%= user._id %>" method="POST">
            <input class="px-5 py-2 border-2 border-zinc-800 outline-none bg-transparent rounded" type="text" placeholder="name" name="name" value="<%=user.name%>">
            <input class="px-5 py-2 border-2 border-zinc-800 outline-none bg-transparent rounded ml-3" type="text" placeholder="email" name="email" value="<%=user.email%>">
            <input class="px-5 py-2 border-2 border-zinc-800 outline-none bg-transparent rounded ml-3" type="text" placeholder="img-url" name="image" value="<%=user.image%>">

            <input class="px-5 py-2 text-black bg-yellow-500 rounded ml-5" type="submit" value="Update">

        </form>
    </div>
</body>
</html>