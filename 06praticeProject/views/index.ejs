<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File handling Project</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="create" method="post">
                <input class="block w-full rounded outline-none px-5 py-2 bg-zinc-800" type="text" placeholder="write title" name="title">
                <textarea class="block w-full rounded outline-none resize-none px-5 py-2 bg-zinc-800 mt-2" placeholder="write about your note." name="details"></textarea>
                <input class="mt-5 bg-blue-500 rounded-md px-5 py-2" type="submit" value="Create Tasks">
            </form>
        </div>

        <div class="tasks flex flex-wrap p-10 gap-3">
            <% if(files.length>0){ %>
               <% files.forEach((val)=>{ %>
                    <div class="w-72 px-4 py-3 rounded-md bg-zinc-800">
                        <h1 class="text-white text-3xl tracking-tighter mt-3"><%= val %></h1>
                        <div class="flex justify-between w-full space-x-4 text-center mt-3">
                            <a href="/file/<%= val %>" class="inline-block text-blue-600 ">Read more</a>
                            <a href="/edit/<%= val %>" class="text-zinc-500 underline">Edit</a>
                        </div>
                    </div>
                <% })%>
            <% } else{ %>
                <h3 class="text-zinc-500">No tasks yet.</h3>
            <% } %>

        </div>
    </div>
</body>
</html>