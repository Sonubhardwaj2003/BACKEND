<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-600 inline-block mb-5 underline" href="/"> Go Back Home</a>
        <div class="form text-white">
            <form action="/edit" method="post">
                <input class="block w-1/4 rounded outline-none px-5 py-2 bg-zinc-800 " type="text" placeholder="Previous name" name="Previous" value="<%= filename %>" >

                <input class="block w-1/4 rounded outline-none px-5 py-2 bg-zinc-800 mt-2" placeholder="New name" name="New"></input>

                <input class="mt-5 bg-yellow-500 rounded-md px-5 py-2" type="submit" value="Update Name">
            </form>
        </div>
    </div>
</body>
</html>